<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Social Media - Posts</title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="app-shell">
  <nav class="app-nav z-depth-0">
    <div class="nav-wrapper container">
      <a href="/" class="brand-logo app-brand teal-text text-darken-2">Social Media</a>
      <ul class="right hide-on-med-and-down">
        <li><a href="/">Inicio</a></li>
        <li><a href="/posts">Posts</a></li>
        <li><a href="/posts/new">Nuevo Post</a></li>
      </ul>
    </div>
  </nav>

  <main class="container page-wrap">
    <div class="row">
      <div class="col s12 m4">
        <aside class="form-panel">
          <div class="form-banner">
            <img src="https://images.unsplash.com/photo-1499750310107-5fef28a66643?auto=format&fit=crop&w=900&q=80" alt="Compartiendo contenido social">
          </div>
          <div class="section-heading">
            <div>
              <h5 class="teal-text">Nuevo Post</h5>
              <p class="section-muted">Crea publicaciones con imagen, hashtags y enlaces.</p>
            </div>
          </div>
          <% if (typeof error !== 'undefined' && error) { %>
            <div class="card-panel red lighten-4 red-text text-darken-4"><%= error %></div>
          <% } %>

          <form action="/posts" method="POST">
            <div class="input-field">
              <select name="userId" required>
                <option value="" disabled selected>Selecciona usuario</option>
                <% users.forEach((user) => { %>
                  <option value="<%= user._id %>"><%= user.name %> <%= user.lastName %></option>
                <% }) %>
              </select>
              <label>Usuario</label>
            </div>

            <div class="input-field">
              <input id="title" name="title" type="text" minlength="5" maxlength="30" required>
              <label for="title">Título</label>
            </div>

            <div class="input-field">
              <textarea id="content" name="content" class="materialize-textarea" minlength="10" required></textarea>
              <label for="content">Contenido</label>
            </div>

            <div class="input-field">
              <input id="hashtags" name="hashtags" type="text" placeholder="ejemplo, social, nodejs">
              <label for="hashtags">Hashtags</label>
            </div>

            <div class="input-field">
              <input id="imageUrl" name="imageUrl" type="url" placeholder="https://...">
              <label for="imageUrl">Imagen por enlace</label>
            </div>

            <button type="submit" class="btn waves-effect waves-light teal darken-2">Guardar post</button>
          </form>
        </aside>
      </div>

      <div class="col s12 m8">
        <section class="feed-panel" style="padding: 22px; margin-block-end: 24px;">
          <div class="feed-banner">
            <img src="https://images.unsplash.com/photo-1516321497487-e288fb19713f?auto=format&fit=crop&w=1400&q=80" alt="Publicaciones de social media">
          </div>
          <div class="section-heading" style="margin-block-end: 0;">
            <div>
              <h4>Posts de todos los usuarios</h4>
              <p class="section-muted">Explora imágenes, enlaces y publicaciones de la comunidad.</p>
            </div>
          </div>
        </section>

        <div class="row">
          <% if (posts && posts.length > 0) { %>
            <% posts.forEach((post) => { %>
              <div class="col s12 m6">
                <article class="post-card">
                  <div class="card-image">
                    <% if (post.imageUrl) { %>
                      <img src="<%= post.imageUrl %>" alt="Imagen del post">
                    <% } else { %>
                      <div class="center-align" style="padding: 24px; display:flex; flex-direction:column; align-items:center; justify-content:center; min-block-size: 230px;">
                        <i class="material-icons large teal-text">image_search</i>
                        <p class="grey-text text-darken-1" style="margin: 0;">Sin imagen. Agrega un enlace para mostrarla.</p>
                      </div>
                    <% } %>
                  </div>
                  <div class="post-body">
                    <div class="post-title"><%= post.title %></div>
                    <p class="post-content"><%= post.content %></p>
                    <p style="margin-block-start: 14px;">
                      <strong>Hashtags:</strong>
                      <% if (post.hashtags && post.hashtags.length > 0) { %>
                        <% post.hashtags.forEach((tag) => { %>
                          <span class="chip">#<%= tag %></span>
                        <% }) %>
                      <% } else { %>
                        <span class="grey-text">Sin hashtags</span>
                      <% } %>
                    </p>
                  </div>
                  <div class="post-meta">
                    <div class="post-author">
                      <strong>Autor:</strong>
                      <%= post.user ? `${post.user.name} ${post.user.lastName}` : "Sin autor" %>
                      <% if (post.imageUrl) { %>
                        <div style="margin-block-start: 8px;">
                          <a href="<%= post.imageUrl %>" target="_blank" rel="noopener noreferrer">Abrir imagen en una nueva pestaña</a>
                        </div>
                      <% } %>
                    </div>
                    <div class="action-row">
                      <a href="/posts/edit/<%= post._id %>" class="btn-small waves-effect waves-light teal darken-2"><i class="material-icons left">edit</i>Editar</a>
                      <form action="/posts/delete/<%= post._id %>" method="POST" style="display:inline;">
                        <button type="submit" class="btn-small waves-effect waves-light red darken-1"><i class="material-icons left">delete</i>Eliminar</button>
                      </form>
                    </div>
                  </div>
                </article>
              </div>
            <% }) %>
          <% } else { %>
            <div class="col s12">
              <p class="flow-text center-align">No hay publicaciones registradas todavía.</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </main>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const selects = document.querySelectorAll('select');
      M.FormSelect.init(selects);
    });
  </script>
</body>
</html>