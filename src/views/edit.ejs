<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Editar Post</title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="app-shell">
  <nav class="app-nav z-depth-0">
    <div class="nav-wrapper container">
      <a href="/posts" class="brand-logo app-brand teal-text text-darken-2">Social Media</a>
      <ul class="right hide-on-med-and-down">
        <li><a href="/">Inicio</a></li>
        <li><a href="/posts">Posts</a></li>
      </ul>
    </div>
  </nav>

  <main class="container page-wrap" style="max-inline-size: 760px;">
    <section class="edit-panel panel" style="padding: 22px;">
      <div class="edit-banner">
        <img src="https://images.unsplash.com/photo-1487412720507-e7ab37603c6f?auto=format&fit=crop&w=1200&q=80" alt="Editar publicaciones en Social Media">
      </div>
      <div class="section-heading">
        <div>
          <h4>Editar Post</h4>
          <p class="section-muted">Actualiza texto, hashtags, enlaces e imagen por URL.</p>
        </div>
      </div>

      <% const currentUserId = post.user ? String(post.user._id) : ""; %>

      <form action="/posts/edit/<%= post._id %>" method="POST">
        <div class="input-field">
          <select name="userId" required>
            <% users.forEach((user) => { %>
              <option value="<%= user._id %>" <%= currentUserId === String(user._id) ? 'selected' : '' %>><%= user.name %> <%= user.lastName %></option>
            <% }) %>
          </select>
          <label>Usuario</label>
        </div>

        <div class="input-field">
          <input id="title" name="title" type="text" minlength="5" maxlength="30" value="<%= post.title %>" required>
          <label for="title" class="active">Título</label>
        </div>

        <div class="input-field">
          <textarea id="content" name="content" class="materialize-textarea" minlength="10" required><%= post.content %></textarea>
          <label for="content" class="active">Contenido</label>
        </div>

        <div class="input-field">
          <input id="hashtags" name="hashtags" type="text" value="<%= post.hashtags ? post.hashtags.join(', ') : '' %>">
          <label for="hashtags" class="active">Hashtags</label>
        </div>

        <div class="input-field">
          <input id="imageUrl" name="imageUrl" type="url" value="<%= post.imageUrl || '' %>">
          <label for="imageUrl" class="active">Imagen por enlace</label>
        </div>

        <button type="submit" class="btn waves-effect waves-light teal darken-2">Actualizar cambios</button>
        <a href="/posts" class="btn-flat">Cancelar</a>
      </form>
    </section>
  </main>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const selects = document.querySelectorAll('select');
      M.FormSelect.init(selects);
    });
  </script>
</body>
</html>
